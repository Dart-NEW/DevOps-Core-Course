apiVersion: 1

datasources:
  - name: Loki
    uid: loki
    type: loki
    access: proxy
    url: http://loki:{{ monitoring_loki_port }}
    isDefault: true
    editable: true

  - name: Prometheus
    uid: prometheus
    type: prometheus
    access: proxy
    url: http://prometheus:{{ monitoring_prometheus_port }}
    isDefault: false
    editable: true
